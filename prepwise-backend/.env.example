# Copy this file to .env and adjust as needed.
# When using docker-compose, these are already set on the "backend" service,
# so a local .env is only needed if you run `npm run dev` on your host machine
# against the dockerized Postgres (use DATABASE_URL below in that case).

PORT=5000

# Use this when running the backend with `npm run dev` on your host,
# pointing at the Postgres container exposed on localhost:5432
DATABASE_URL="postgresql://neondb_owner:npg_Y1NTR0kXwCSi@ep-quiet-hall-at2wv5b0-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

JWT_SECRET=change_this_dev_secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173
